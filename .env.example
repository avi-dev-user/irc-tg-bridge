# irc-tg-bridge configuration. Copy to /etc/irc-tg-bridge/env (chmod 600).
# Holds secrets: never commit it (see .gitignore).

# --- Telegram ---
# Bot token from @BotFather.
BOT_TOKEN=123456:ABC-your-bot-token-here
# api_id / api_hash from https://my.telegram.org (Pyrogram needs these).
API_ID=0
API_HASH=your-api-hash
# Your numeric Telegram user id (management is limited to this id).
ADMIN_TELEGRAM_ID=000000000

# --- WeeChat api relay ---
# Must match the WeeChat relay password and port on this host.
RELAY_HOST=127.0.0.1
RELAY_PORT=9799
RELAY_SECRET=the-relay-password

# --- WeeChat secured data (only once IRC servers store passwords) ---
# Passphrase that unlocks WeeChat's encrypted sec.conf.
SECURE_PASSPHRASE=change-me-to-a-strong-passphrase
